# Game Application Environment Configuration

# Application Environment
ENVIRONMENT=production
APP_NAME=game-arena
APP_VERSION=1.0.0

# Backend Configuration
BACKEND_PORT=3000
BACKEND_LOG_LEVEL=info
BACKEND_NODE_ENV=production
BACKEND_MAX_PLAYERS=4
BACKEND_HEALTH_CHECK_INTERVAL=30s

# Frontend Configuration
FRONTEND_PORT=3001
FRONTEND_API_URL=http://localhost:3000
FRONTEND_WS_URL=ws://localhost:3000/ws

# Docker Registry
REGISTRY=artifactory.company.com
IMAGE_NAMESPACE=game-app
IMAGE_VERSION=latest

# Kubernetes Configuration
K8S_NAMESPACE=game-app
K8S_CLUSTER=production-cluster
REPLICAS_BACKEND=3
REPLICAS_FRONTEND=2

# Scaling
AUTO_SCALE_BACKEND_MIN=2
AUTO_SCALE_BACKEND_MAX=10
AUTO_SCALE_FRONTEND_MIN=1
AUTO_SCALE_FRONTEND_MAX=5
CPU_TARGET_PERCENT=70
MEMORY_TARGET_PERCENT=80

# Database/Storage (if needed in future)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=game_app
DB_USER=game_user

# Security
ENABLE_HTTPS=true
ENABLE_CORS=true
CORS_ORIGIN=*
SESSION_SECRET=your-secret-key-here

# Monitoring
ENABLE_METRICS=true
METRICS_PORT=9090
LOG_AGGREGATION_ENABLED=true

# Feature Flags
ENABLE_CHAT=true
ENABLE_LEADERBOARD=true
ENABLE_REPLAY=false

# External Services
JFROG_REGISTRY=artifactory.company.com
JFROG_USERNAME=your-username
ARGOCD_SERVER=argocd.company.com
SLACK_WEBHOOK=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
